# Environment configuration for local development
# Copy this file to .env and fill in your API keys

# OpenAI Configuration (optional - uses fallback if not set)
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Tavily Configuration (optional - uses mock data if not set)
# Get your key from: https://tavily.com (1000 searches/month free)
TAVILY_API_KEY=

# LLM Configuration
# Set USE_OLLAMA=true for development (uses local Ollama), false for production (uses OpenAI)
USE_OLLAMA=true
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# Application Settings
ENVIRONMENT=development
LOG_LEVEL=INFO
